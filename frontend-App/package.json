{
  "name": "frontend-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mobile": "vite --mode mobile",
    "build": "vite build",
    "build:mobile": "vite build --mode mobile",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:mobile": "vite preview --mode mobile",
    "cap:sync": "npx cap sync android",
    "cap:build": "npm run build:mobile && npx cap sync android",
    "cap:open": "npx cap open android",
    "android:build": "cd android; .\\gradlew.bat assembleDebug",
    "android:release": "cd android; .\\gradlew.bat assembleRelease",
    "apk:debug": "npm run cap:build && npm run android:build",
    "apk:release": "npm run cap:build && npm run android:release"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/app": "^7.0.2",
    "@capacitor/cli": "^7.4.2",
    "@capacitor/core": "^7.4.2",
    "@tailwindcss/vite": "^4.1.11",
    "axios": "^1.10.0",
    "lucide-react": "^0.525.0",
    "node-fetch": "^3.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.3",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "terser": "^5.43.1",
    "vite": "^7.0.0"
  }
}
